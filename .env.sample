# Browser-side API base URL. Leave empty in dev — the Vite proxy forwards /v1
# to the backend, so requests stay same-origin and the backend needs no CORS.
# In production set it to the API origin (and set CORS_ALLOWED_ORIGINS on the backend).
VITE_API_BASE_URL=

# Server-side base URL for SSR prefetch (read by server.js from the process
# environment, not from this file — e.g. `API_BASE_URL=… pnpm run dev:ssr`).
API_BASE_URL=http://localhost:9000

# OpenObserve RUM (optional — leave unset and it never loads).
# Get the client token from OpenObserve → Ingestion → Client Token.
# VITE_OPENOBSERVE_RUM_CLIENT_TOKEN=
# VITE_OPENOBSERVE_RUM_SITE=localhost:55080
# VITE_OPENOBSERVE_RUM_ORG=default
# VITE_OPENOBSERVE_RUM_APPLICATION_ID=madrileno-frontend
