{
  "name": "madrileno-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "node server",
    "build": "tsc -b && vite build",
    "build:ssr": "tsc -b && vite build --outDir dist/client && vite build --ssr src/app/entry-server.tsx --outDir dist/server",
    "preview": "vite preview",
    "preview:ssr": "cross-env NODE_ENV=production node server",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "sync-contracts": "node scripts/sync-contracts.mjs",
    "init-project": "node scripts/init-project.mjs",
    "e2e:prod": "npm run build:ssr && cross-env E2E_PROD=1 playwright test",
    "smoke:docker": "node scripts/docker-smoke.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@openobserve/browser-logs": "^0.3.4",
    "@openobserve/browser-rum": "^0.3.4",
    "@orpc/client": "^1.14.6",
    "@orpc/contract": "^1.14.6",
    "@orpc/openapi-client": "^1.14.6",
    "@orpc/tanstack-query": "^1.14.6",
    "@tanstack/react-query": "^5.101.2",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "sirv": "^3.0.2",
    "temporal-polyfill": "^1.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.9"
  }
}
