{
  "name": "madrileno-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:ssr": "pnpm run paraglide:compile && node server",
    "build": "pnpm run paraglide:compile && tsc -b && vite build",
    "build:ssr": "pnpm run paraglide:compile && tsc -b && vite build --outDir dist/client && vite build --ssr src/app/entry-server.tsx --outDir dist/server",
    "preview": "vite preview",
    "preview:ssr": "cross-env NODE_ENV=production node server",
    "typecheck": "pnpm run paraglide:compile && tsc -b",
    "lint": "pnpm run paraglide:compile && eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run paraglide:compile && vitest run",
    "test:watch": "pnpm run paraglide:compile && vitest",
    "e2e": "playwright test",
    "sync-contracts": "node scripts/sync-contracts.mjs",
    "init-project": "node scripts/init-project.mjs",
    "generate-pwa-assets": "pwa-assets-generator",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
    "e2e:prod": "npm run build:ssr && cross-env E2E_PROD=1 playwright test",
    "smoke:docker": "node scripts/docker-smoke.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@hookform/resolvers": "^5.4.0",
    "@openobserve/browser-logs": "^0.3.4",
    "@openobserve/browser-rum": "^0.3.4",
    "@orpc/client": "^1.14.6",
    "@orpc/contract": "^1.14.6",
    "@orpc/openapi-client": "^1.14.6",
    "@orpc/tanstack-query": "^1.14.6",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "express": "^5.2.1",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.1",
    "shadcn": "^4.13.0",
    "sirv": "^3.0.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "temporal-polyfill": "^1.0.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.0",
    "@inlang/paraglide-js": "^2.22.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "msw": "^2.14.6",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-window": "^7.4.1"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "msw"
    ]
  }
}
